# ============================================================
# Safe Agentic AI — Environment Configuration
# ============================================================
# RECOMMENDED: Run ./setup.sh to generate this file automatically.
# Or copy to .env and configure manually:  cp .env.example .env
# ============================================================

# --- Project Name (unique per project clone) ------------------
# Each project should have its own copy of this folder.
# Used for container names: <name>-workspace, <name>-proxy
# Lowercase, letters/numbers/hyphens only.
PROJECT_NAME=my-project

# --- Platform (auto-detected by setup.sh) -------------------
# Values: macos, windows, linux
PLATFORM=

# --- Container Architecture ------------------------------------
# linux/amd64 (default): works everywhere, includes Playwright MCP
# linux/arm64 (native):  faster on Apple Silicon, no Playwright MCP
CONTAINER_PLATFORM=linux/amd64
INSTALL_PLAYWRIGHT=true

# --- Git Identity (used inside container) --------------------
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your.email@example.com

# --- SSH Agent Provider --------------------------------------
# Which SSH agent do you use? (1password, keeper, custom, none)
SSH_AGENT_PROVIDER=1password

# --- SSH Agent Socket (host path) ----------------------------
# 1Password:
#   macOS:   ${HOME}/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock
#   Windows: /run/host-services/ssh-auth.sock
#   Linux:   ${HOME}/.1password/agent.sock
# Keeper PAM:
#   macOS/Linux: ${HOME}/.keeper/<your-email>.ssh_agent
# Custom:
#   Set to your SSH_AUTH_SOCK path
SSH_AGENT_SOCK_HOST=

# --- 1Password CLI (for op run/read inside container) ---
# App integration (biometric) does not work cross-platform in Docker.
# Set a service account token instead:
# OP_SERVICE_ACCOUNT_TOKEN=
# Or resolve secrets on host with 'op read' and pass as env vars.

# --- Workspace Path (host directory mounted as /workspace) ---
# Your project code goes here. Defaults to the workspace/ subdirectory
# inside this project folder, keeping everything self-contained.
WORKSPACE_PATH=./workspace

# --- SSH Keys Path (mounted read-only) ----------------------
SSH_HOST_PATH=${HOME}/.ssh

# --- Resource Limits ----------------------------------------
# Adjust based on your machine.
WORKSPACE_MEMORY=4G
WORKSPACE_CPUS=4
PROXY_MEMORY=256M
PROXY_CPUS=1
TMP_SIZE=536870912

# --- Claude CLI Overrides (all optional) --------------------
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# CLAUDE_MODEL=claude-opus-4-20250514
# CLAUDE_MAX_TURNS=25

# --- SSH Signing Key (for git commit signing) ----------------
# Path INSIDE the container to your public key (optional)
# SSH_SIGNING_KEY=/home/vscode/.ssh/id_rsa.pub
